# STT provider: deepgram (default) or openai
STT_PROVIDER=deepgram

# LLM provider: gemini (default), openai, or opencode
LLM_PROVIDER=gemini

# LiveKit — https://cloud.livekit.io
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_SIP_URI=your-project-id.sip.livekit.cloud
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=

# Deepgram — https://console.deepgram.com (required if STT_PROVIDER=deepgram)
DEEPGRAM_API_KEY=

# Google AI — https://aistudio.google.com (required if LLM_PROVIDER=gemini)
GOOGLE_API_KEY=

# OpenAI — https://platform.openai.com (required if STT_PROVIDER=openai or LLM_PROVIDER=openai)
OPENAI_API_KEY=

# OpenCode — https://opencode.ai (required if LLM_PROVIDER=opencode)
OPENCODE_API_KEY=

# Murf TTS — https://murf.ai/api/dashboard
MURF_API_KEY=

# Twilio — https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+12015551234
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Twilio Elastic SIP trunk (for setup_outbound_trunk.py — run once)
TWILIO_SIP_TERM_URI=livekit-outbound.pstn.twilio.com
TWILIO_SIP_USERNAME=
TWILIO_SIP_PASSWORD=

# Human handoff — SIP transfer when the agent escalates (optional)
HUMAN_TRANSFER_NUMBER=+918041234567
